<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bq_canvas"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_screen_panel"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="@color/bq_text_muted"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Create Account"
                android:textColor="@color/bq_text_dark"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Join BudgetQuest — it's free"
                android:textColor="@color/bq_text_muted"
                android:textSize="13sp" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="USERNAME" />

            <EditText
                android:id="@+id/username"
                style="@style/Widget.BudgetQuest.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="Min. 4 characters" />
            <TextView android:id="@+id/usernameError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PASSWORD" />
            <EditText android:id="@+id/password" style="@style/Widget.BudgetQuest.Input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:hint="Min. 8 chars, 1 number, 1 cap" android:inputType="textPassword" />
            <TextView android:id="@+id/passwordError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="CONFIRM PASSWORD" />
            <EditText android:id="@+id/confirmPassword" style="@style/Widget.BudgetQuest.Input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:hint="Repeat password" android:inputType="textPassword" />
            <TextView android:id="@+id/confirmError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="SECURITY QUESTION" />
            <Spinner android:id="@+id/securityQuestion" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="ANSWER" />
            <EditText android:id="@+id/securityAnswer" style="@style/Widget.BudgetQuest.Input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:hint="Your answer" />
            <TextView android:id="@+id/answerError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />
            <TextView android:id="@+id/generalError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />

            <Button android:id="@+id/registerBtn" style="@style/Widget.BudgetQuest.PrimaryButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Create Account" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
