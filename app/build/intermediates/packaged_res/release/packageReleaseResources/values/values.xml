<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#000000</color>
    <color name="bq_accent">#F19960</color>
    <color name="bq_bg">#111316</color>
    <color name="bq_canvas">#111316</color>
    <color name="bq_header">#1A1D38</color>
    <color name="bq_input_bg">#23264A</color>
    <color name="bq_input_border">#313666</color>
    <color name="bq_link">#F19960</color>
    <color name="bq_panel">#1A1D38</color>
    <color name="bq_safe">#36D58D</color>
    <color name="bq_surface">#171A30</color>
    <color name="bq_tab_active">#F19960</color>
    <color name="bq_tab_inactive">#8E98A3</color>
    <color name="bq_text_dark">#F7F8FF</color>
    <color name="bq_text_muted">#A8ADD1</color>
    <color name="bq_text_primary">#FFFFFF</color>
    <color name="bq_text_secondary">#B0BEC5</color>
    <color name="bq_warning">#E53935</color>
    <color name="ic_launcher_background">#1A1D38</color>
    <color name="white">#FFFFFF</color>
    <string name="app_name">BudgetQuest</string>
    <style name="Theme.BudgetQuest" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/bq_panel</item>
        <item name="android:navigationBarColor">@color/bq_panel</item>
        <item name="colorPrimary">@color/bq_accent</item>
        <item name="colorOnPrimary">@color/bq_bg</item>
        <item name="android:windowBackground">@color/bq_bg</item>
    </style>
    <style name="Widget.BudgetQuest" parent="@style/Theme.BudgetQuest"/>
    <style name="Widget.BudgetQuest.GoldButton">
        <item name="android:background">@drawable/bg_button_gold</item>
        <item name="android:textColor">@color/bq_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="Widget.BudgetQuest.Input" parent="@android:style/Widget.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:textColor">@color/bq_text_dark</item>
        <item name="android:textColorHint">@color/bq_text_muted</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Widget.BudgetQuest.PrimaryButton">
        <item name="android:background">@drawable/bg_button_green</item>
        <item name="android:textColor">@color/bq_bg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="Widget.BudgetQuest.SectionLabel">
        <item name="android:textColor">@color/bq_text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>
</resources>