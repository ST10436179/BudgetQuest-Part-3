<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bq_canvas">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Good morning,"
                        android:textColor="@color/bq_text_muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/welcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/bq_text_dark"
                        android:textSize="34sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/levelBadge"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_chip"
                    android:gravity="center"
                    android:textColor="@color/bq_accent"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/bq_text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_dashboard_total_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    style="@style/Widget.BudgetQuest.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TOTAL SPENT THIS MONTH"
                    android:textColor="#BFD3EC" />

                <TextView
                    android:id="@+id/goalRangeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#BFD3EC"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/gaugeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/budgetStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/bq_safe"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/gauge"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progressTint="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/statusCard1"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_dark_card"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="@color/bq_text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <Space android:layout_width="10dp" android:layout_height="1dp" />
                <TextView
                    android:id="@+id/statusCard2"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_dark_card"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="@color/bq_text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/statusCard3"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_dark_card"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="@color/bq_text_dark"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <Space android:layout_width="10dp" android:layout_height="1dp" />
                <TextView
                    android:id="@+id/statusCard4"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_dark_card"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:textColor="#FF5A5A"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="OVERSPENT CATEGORIES" />

            <LinearLayout
                android:id="@+id/overspendContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dark_card"
                android:orientation="vertical"
                android:padding="10dp" />

            <TextView
                style="@style/Widget.BudgetQuest.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="RECENT EXPENSES" />

            <LinearLayout
                android:id="@+id/recentListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_dark_card"
                android:orientation="vertical"
                android:padding="10dp" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="+"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/bq_accent"
        app:tint="@color/bq_bg" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
