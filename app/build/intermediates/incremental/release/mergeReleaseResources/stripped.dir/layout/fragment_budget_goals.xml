<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bq_canvas">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_header_block" android:orientation="vertical" android:padding="16dp">
            <Button android:id="@+id/backBtn" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@android:color/transparent" android:text="← Profile" android:textAllCaps="false" android:textColor="@color/bq_text_muted" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Budget Goals" android:textColor="@color/white" android:textSize="30sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Set your monthly targets" android:textColor="@color/bq_text_muted" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/bq_panel" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_soft_card" android:padding="12dp" android:text="💡 Set a minimum you plan to spend and a maximum not to exceed each month." android:textColor="@color/bq_text_dark" android:textStyle="bold" />
            <TextView style="@style/Widget.BudgetQuest.SectionLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="MONTHLY MINIMUM GOAL" />
            <EditText android:id="@+id/minGoal" style="@style/Widget.BudgetQuest.Input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:hint="R 1,000" android:inputType="numberDecimal" />
            <TextView style="@style/Widget.BudgetQuest.SectionLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="MONTHLY MAXIMUM GOAL" />
            <EditText android:id="@+id/maxGoal" style="@style/Widget.BudgetQuest.Input" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:hint="R 5,000" android:inputType="numberDecimal" />
            <TextView style="@style/Widget.BudgetQuest.SectionLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="PER-CATEGORY LIMITS" />
            <LinearLayout android:id="@+id/categoryLimitContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="vertical" />
            <TextView android:id="@+id/errorText" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_warning" />
            <Button android:id="@+id/saveBtn" style="@style/Widget.BudgetQuest.PrimaryButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Save Goals" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
