<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bq_canvas">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_header_block" android:gravity="center_horizontal" android:orientation="vertical" android:padding="18dp">
            <TextView android:id="@+id/avatar" android:layout_width="64dp" android:layout_height="64dp" android:background="@drawable/bg_chip" android:gravity="center" android:textColor="@color/bq_accent" android:textSize="28sp" android:textStyle="bold" />
            <TextView android:id="@+id/username" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:gravity="center" android:textColor="@color/white" android:textSize="30sp" android:textStyle="bold" />
            <TextView android:id="@+id/memberSince" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:textColor="@color/bq_text_muted" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/bq_panel" android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_soft_card" android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/rank" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/bq_accent" android:textStyle="bold" />
                <TextView android:id="@+id/xpProgress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/bq_text_muted" />
                <ProgressBar android:id="@+id/levelProgress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:max="2000" android:progressTint="@color/bq_safe" />
            </LinearLayout>

            <TextView style="@style/Widget.BudgetQuest.SectionLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="BADGES EARNED" />
            <TextView android:id="@+id/badgeFirst" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:background="@drawable/bg_input_field" android:padding="12dp" android:text="🥇  First Entry" android:textColor="@color/bq_text_dark" />
            <TextView android:id="@+id/badgeWeek" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:padding="12dp" android:text="⚔️  Week Warrior" android:textColor="@color/bq_text_dark" />
            <TextView android:id="@+id/badgeHero" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:padding="12dp" android:text="🏆  Budget Hero" android:textColor="@color/bq_text_dark" />

            <Button android:id="@+id/manageCategories" style="@style/Widget.BudgetQuest.PrimaryButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="⚙️ Manage Categories" />
            <Button android:id="@+id/setGoals" style="@style/Widget.BudgetQuest.PrimaryButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="🎯 Set Budget Goals" />
            <Button android:id="@+id/logoutBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_button_gold" android:text="Log Out" android:textAllCaps="false" android:textColor="@color/bq_warning" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
